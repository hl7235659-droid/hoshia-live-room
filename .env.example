# Server exposure. Keep the default private to localhost for Tailscale Serve.
LIVE_ROOM_BIND_HOST=127.0.0.1
LIVE_ROOM_PORT=18888

# Session security. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-a-long-random-secret
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=false

# Room tokens are SHA-256 hex digests. The room token opens the gate before login or registration.
# Generate with: node gateway/scripts/hash-invite.mjs "your-room-token"
ROOM_TOKEN_HASHES=replace-with-sha256-hex

# SQLite account database. Docker Compose overrides this to /app/data/live-room.sqlite.
SQLITE_DB_PATH=./data/live-room.sqlite

# Optional allow-list for display names. Leave empty to allow any nickname with a valid registration code.
ALLOWED_NICKNAMES=

# Room behavior.
ROOM_ID=live-room-dev
ADMIN_QQ_ID=387780063
MAX_MESSAGE_LENGTH=500
MESSAGE_RATE_LIMIT_WINDOW_SECONDS=10
MESSAGE_RATE_LIMIT_COUNT=8

# AI backend. Keep mock as the safe default; switch to astrbot only after bridge plugin is installed.
AI_MODE=mock
ASTRBOT_BRIDGE_URL=http://astrbot:18081/live-room/generate
ASTRBOT_BRIDGE_TOKEN=replace-with-shared-bridge-token
ASTRBOT_TIMEOUT_MS=15000
ASTRBOT_FALLBACK_TO_MOCK=true

# Frontend Live2D. Leave VITE_LIVE2D_MODEL_URL empty until Cubism export files exist.
VITE_LIVE2D_MODEL_URL=
VITE_LIVE2D_CORE_URL=/live/live2d/runtime/live2dcubismcore.min.js
