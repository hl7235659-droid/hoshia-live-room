# Server exposure. Keep the default private to localhost for Tailscale Serve.
LIVE_ROOM_BIND_HOST=127.0.0.1
LIVE_ROOM_PORT=18888

# Session security. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-generate-a-long-random-secret
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=false

# QQ email verification for registration. Use provider-specific SMTP app passwords only in private .env files.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-with-sender@qq.com
SMTP_PASS=replace-with-smtp-app-password
SMTP_FROM=replace-with-sender@qq.com
REGISTER_CODE_TTL_SECONDS=600
REGISTER_CODE_COOLDOWN_SECONDS=60

# SQLite account database. Docker Compose overrides this to /app/data/live-room.sqlite.
SQLITE_DB_PATH=./data/live-room.sqlite

# Optional allow-list for display names. Leave empty to allow any nickname with a valid registration code.
ALLOWED_NICKNAMES=

# Room behavior.
ROOM_ID=live-room-dev
ADMIN_QQ_ID=387780063
MAX_MESSAGE_LENGTH=500
MESSAGE_RATE_LIMIT_WINDOW_SECONDS=10
MESSAGE_RATE_LIMIT_COUNT=8

# AI backend. Keep mock as the safe default; switch to astrbot or hoshiaclaw only after that backend is installed.
AI_MODE=mock
ASTRBOT_BRIDGE_URL=http://astrbot:18081/live-room/generate
ASTRBOT_BRIDGE_TOKEN=replace-with-shared-bridge-token
ASTRBOT_TIMEOUT_MS=45000
ASTRBOT_FALLBACK_TO_MOCK=true
ASTRBOT_STREAMING_ENABLED=true
HOSHIACLAW_BRIDGE_URL=http://live-room-hoshiaclaw:8080/live-room/generate
HOSHIACLAW_TOKEN=replace-with-internal-shared-token
HOSHIACLAW_TIMEOUT_MS=45000
HOSHIACLAW_FALLBACK_TO_MOCK=true
HOSHIACLAW_STREAMING_ENABLED=true
HOSHIACLAW_PROACTIVE_LIVE_ENABLED=false
HOSHIACLAW_PROACTIVE_LIVE_PERCENT=0
HOSHIA_COMMENT_REPLY_ROLLOUT_MODE=off
HOSHIACLAW_DAILY_POST_SHADOW_ENABLED=false
HOSHIACLAW_DAILY_POST_LIVE_ENABLED=false
HOSHIACLAW_NEWS_TOPIC_GENERATE_SHADOW_ENABLED=false
HOSHIACLAW_NEWS_TOPIC_LIVE_ENABLED=false
HOSHIACLAW_LISTEN_ADDR=0.0.0.0:8080
HOSHIACLAW_DATA_DIR=/app/data
HOSHIACLAW_LOG_DIR=/app/logs
HOSHIACLAW_PROVIDER=fake
HOSHIACLAW_OPENAI_BASE_URL=https://api.openai.com/v1
HOSHIACLAW_OPENAI_API_KEY=replace-with-provider-key-in-private-env
HOSHIACLAW_OPENAI_MODEL=replace-with-model-name-in-private-env
HOSHIACLAW_OPENAI_TIMEOUT_MS=30000
HOSHIACLAW_OPENAI_MAX_TOKENS=1200
HOSHIACLAW_OPENAI_TEMPERATURE=0.7
CHARACTER_STATE_AUTHORITY=legacy
SINGLE_USER_DIRECT_REPLY_ENABLED=true
SINGLE_USER_REPLY_DELAY_MS=600
SHORT_TERM_CONTEXT_MAX_MESSAGES=100
CONTEXT_SUMMARY_LOOKBACK_MESSAGES=600
CONTEXT_SUMMARY_COMPRESS_MESSAGES=20

# Reality context injected into Hoshia prompts. Safe summary only; never put secrets here.
REALITY_CONTEXT_ENABLED=true
REALITY_CONTEXT_TIMEZONE=Asia/Shanghai
REALITY_CONTEXT_INCLUDE_OPS=true

# Personalized AI greeting when an account first enters the live room.
WELCOME_GREETING_ENABLED=true
WELCOME_GREETING_COOLDOWN_SECONDS=1800
WELCOME_GREETING_DELAY_MS=900

# Optional idle proactive host replies. Requires AI_MODE=astrbot for real output.
PROACTIVE_REPLY_ENABLED=false
PROACTIVE_REPLY_MIN_IDLE_SECONDS=300
PROACTIVE_REPLY_MAX_IDLE_SECONDS=900
PROACTIVE_REPLY_MAX_UNANSWERED=3
PROACTIVE_REPLY_CONTEXT_MESSAGES=24

# Hoshia life timeline automation.
HOSHIA_ASYNC_COMMENT_REPLY_ENABLED=true
HOSHIA_COMMENT_REPLY_MIN_DELAY_MINUTES=3
HOSHIA_COMMENT_REPLY_MAX_DELAY_MINUTES=45
HOSHIA_COMMENT_REPLY_TICK_LIMIT=2
HOSHIA_COMMENT_REPLY_DAILY_LIMIT=20
HOSHIA_DAILY_POST_ENABLED=true
HOSHIA_DAILY_POST_MIN=1
HOSHIA_DAILY_POST_MAX=5
HOSHIA_STATE_POST_MIN_INTERVAL_MINUTES=90
HOSHIA_STATE_POST_ACTIVE_WINDOW_START=10:00
HOSHIA_STATE_POST_ACTIVE_WINDOW_END=23:50
HOSHIA_NEWS_ENABLED=true
HOSHIA_NEWS_POST_ENABLED=true
HOSHIA_NEWS_POST_DAILY_LIMIT=1
HOSHIA_NEWS_SIGNAL_TTL_HOURS=6
HOSHIA_NEWS_TOPIC_MAX_AGE_HOURS=36

# Music room experimental mode. Keep xiaomusic credentials in xiaomusic's private conf, not here.
MUSIC_ENABLED=false
MUSIC_PROVIDER=xiaomusic
MUSIC_PROVIDER_BASE_URL=http://xiaomusic:8090
MUSIC_ADMIN_USERNAMES=
MUSIC_QUEUE_MAX=20
MUSIC_REQUEST_RATE_LIMIT_WINDOW_SECONDS=60
MUSIC_REQUEST_RATE_LIMIT_COUNT=3
MUSIC_PROVIDER_TIMEOUT_MS=12000
# Search chain format: lx:<platform> tries LXServer first (tx=QQ Music), musicfree:<plugin> falls back to MusicFree plugins.
MUSIC_XIAOMUSIC_SEARCH_CHAIN=musicfree:QQMusicVIP,lx:tx,musicfree:all
QQMUSIC_RESOLVER_PORT=58190

# Frontend Live2D. Leave VITE_LIVE2D_MODEL_URL empty until Cubism export files exist.
VITE_LIVE2D_MODEL_URL=
VITE_LIVE2D_CORE_URL=/live/live2d/runtime/live2dcubismcore.min.js
